# =============================================
# GESTION ARTISTA — Variables de entorno
# =============================================
# Copiar este archivo como .env.local y completar los valores

# Supabase — PROJECT GESTION MUSICA
NEXT_PUBLIC_SUPABASE_URL=https://bszrhmecgklgietfxatf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=           # Copiar de: Supabase > Settings > API Keys > Legacy > anon (public)
SUPABASE_SERVICE_ROLE_KEY=               # Copiar de: Supabase > Settings > API Keys > Legacy > service_role (secret)

# Google APIs (se configura en Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Auto-sync de redes sociales ─────────────────────────────────────────────
# Necesario para sincronización automática diaria de estadísticas.

# YouTube Data API v3
# Obtener en: https://console.cloud.google.com → APIs → YouTube Data API v3 → Credentials → API Key
# (Habilitar la API: https://console.cloud.google.com/apis/library/youtube.googleapis.com)
YOUTUBE_API_KEY=

# Spotify Web API (Client Credentials)
# Crear app en: https://developer.spotify.com/dashboard → Create app
# Redirect URI: http://localhost:3000 (cualquier valor, no se usa OAuth de usuario)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Cron secret — cualquier string aleatorio largo (usado para autenticar el cron de Vercel)
# Ejemplo: openssl rand -hex 32
# Configurar también en Vercel: Settings → Environment Variables → CRON_SECRET
CRON_SECRET=
